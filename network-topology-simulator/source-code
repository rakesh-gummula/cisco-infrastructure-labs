if __name__ == "__main__":
    print("--- Starting Network Simulator ---")
    
    # 1. Initialize the Topology
    lab_network = NetworkTopology()

    # 2. Create two PCs on the same subnet (/24)
    pc1 = Host(hostname="PC-A", ip_with_cidr="192.168.1.10/24", mac_address="AA:AA:AA:AA:AA:AA")
    pc2 = Host(hostname="PC-B", ip_with_cidr="192.168.1.20/24", mac_address="BB:BB:BB:BB:BB:BB")
    
    # Add them to our "network"
    lab_network.add_device(pc1)
    lab_network.add_device(pc2)

    # 3. Simulate PC1 pinging PC2
    pc1.ping("192.168.1.20", lab_network)
    
    # 4. Simulate a failed ping (host doesn't exist)
    pc1.ping("192.168.1.99", lab_network)
